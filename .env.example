# ---- Client-safe (shipped in the browser bundle via Vite) ----
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# ---- Server-only — NEVER expose to the browser ----
# Supabase Dashboard → Settings → API Keys → secret key
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# ---- Admin seed script only ----
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=YourSecurePassword123!
ADMIN_NAME=Your Name
